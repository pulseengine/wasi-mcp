package wasi:mcp@0.1.0;

/// WASI MCP Worlds
///
/// Defines component worlds for MCP servers and clients following the
/// protocol-faithful approach and WASI Preview3 conventions.

// ============================================================================
// MCP Server World
// ============================================================================

/// MCP Server World
///
/// A component that implements an MCP server, providing resources, tools,
/// and prompts to AI systems. Exports typed MCP server operations and
/// imports WASI dependencies for async I/O.
///
/// Use this world for components that:
/// - Expose data sources as MCP resources
/// - Provide executable functions as MCP tools
/// - Offer prompt templates for AI interactions
///
/// Example: A database context provider that exposes schemas as resources
/// and query execution as tools.
@since(version = 0.1.0)
world mcp-server-world {
    // Core WASI dependencies for async I/O
    import wasi:io/poll@0.2.3;
    import wasi:io/streams@0.2.3;
    import wasi:clocks/wall-clock@0.2.3;
    import wasi:clocks/monotonic-clock@0.2.3;

    // MCP server interface - what this component provides
    export server;

    // Optional: streaming support for large resources
    export streaming;
}

// ============================================================================
// MCP Client World
// ============================================================================

/// MCP Client World
///
/// A component that acts as an MCP client, connecting to and consuming
/// MCP servers. Exports typed MCP client operations for calling remote
/// servers.
///
/// Use this world for components that:
/// - Connect to MCP servers to gather context
/// - Aggregate data from multiple MCP sources
/// - Act as AI agents consuming context providers
///
/// Example: An AI assistant that connects to multiple MCP servers to
/// gather context from different data sources before responding.
@since(version = 0.1.0)
world mcp-client-world {
    // Core WASI dependencies for async I/O
    import wasi:io/poll@0.2.3;
    import wasi:io/streams@0.2.3;
    import wasi:clocks/wall-clock@0.2.3;
    import wasi:clocks/monotonic-clock@0.2.3;

    // MCP client interface - what this component provides
    export client;

    // Optional: streaming support for large data
    import streaming;
}

// ============================================================================
// MCP Proxy World
// ============================================================================

/// MCP Proxy World
///
/// A component that acts as both server and client, enabling MCP server
/// composition, aggregation, and middleware functionality.
///
/// Use this world for components that:
/// - Aggregate multiple upstream MCP servers
/// - Add caching or filtering to MCP servers
/// - Implement authentication/authorization middleware
/// - Transform or enrich MCP responses
///
/// Example: A caching proxy that aggregates resources from multiple
/// backend MCP servers while adding a caching layer to improve performance.
@since(version = 0.1.0)
world mcp-proxy-world {
    // Core WASI dependencies for async I/O
    import wasi:io/poll@0.2.3;
    import wasi:io/streams@0.2.3;
    import wasi:clocks/wall-clock@0.2.3;
    import wasi:clocks/monotonic-clock@0.2.3;

    // Act as both server (downstream) and client (upstream)
    export server;
    export client;
    export streaming;
}
