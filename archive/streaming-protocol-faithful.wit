package wasi:mcp@0.1.0;

/// MCP Streaming Interface
///
/// Provides streaming operations for large resources and long-running tools.
/// Integrates with wasi:io/streams for efficient data transfer.
/// Following WASI Preview3 streaming patterns.
@since(version = 0.1.0)
interface streaming {
    use types.{error};
    use wasi:io/streams@0.2.3.{input-stream, output-stream};
    use wasi:io/poll@0.2.3.{pollable};
    use wasi:clocks/wall-clock@0.2.3.{datetime};

    // ============================================================================
    // Streaming Resource
    // ============================================================================

    /// Streaming resource for large content
    ///
    /// Provides stream-based access to resource content, avoiding the need
    /// to load entire resources into memory or encode as base64.
    @since(version = 0.1.0)
    resource streaming-resource {
        /// Open an input stream for reading
        @since(version = 0.1.0)
        open-stream: func() -> result<input-stream, error>;

        /// Get resource size (if known)
        @since(version = 0.1.0)
        size: func() -> option<u64>;

        /// Check if seekable
        @since(version = 0.1.0)
        is-seekable: func() -> bool;

        /// Seek to position
        @since(version = 0.1.0)
        seek: func(offset: u64) -> result<u64, error>;

        /// Subscribe to changes
        @since(version = 0.1.0)
        subscribe: func() -> pollable;

        /// Get last modified time
        @since(version = 0.1.0)
        last-modified: func() -> option<datetime>;
    }

    // ============================================================================
    // Chunked Reader
    // ============================================================================

    /// Chunked reader for progressive loading
    ///
    /// Reads large resources in manageable chunks with progress tracking.
    @since(version = 0.1.0)
    resource chunked-reader {
        /// Read next chunk
        @since(version = 0.1.0)
        read-chunk: func() -> future<result<option<list<u8>>, error>>;

        /// Current position
        @since(version = 0.1.0)
        position: func() -> u64;

        /// Total bytes read
        @since(version = 0.1.0)
        bytes-read: func() -> u64;

        /// Progress percentage (0-100)
        @since(version = 0.1.0)
        progress-percent: func() -> option<f32>;

        /// Check if at end
        @since(version = 0.1.0)
        is-end: func() -> bool;

        /// Reset to beginning
        @since(version = 0.1.0)
        reset: func() -> future<result<_, error>>;
    }

    // ============================================================================
    // Factory Functions
    // ============================================================================

    /// Create streaming resource from URI
    ///
    /// Opens a resource for streaming access.
    @since(version = 0.1.0)
    create-streaming-resource: func(uri: string)
        -> future<result<streaming-resource, error>>;

    /// Create chunked reader
    ///
    /// Creates a reader that processes a resource in chunks.
    @since(version = 0.1.0)
    create-chunked-reader: func(
        stream-resource: streaming-resource,
        chunk-size: u64
    ) -> result<chunked-reader, error>;

    // ============================================================================
    // Stream Utilities
    // ============================================================================

    /// Copy stream data
    ///
    /// Efficiently copies from input to output stream.
    @since(version = 0.1.0)
    copy-stream: func(
        input: input-stream,
        output: output-stream
    ) -> future<result<u64, error>>;
}
